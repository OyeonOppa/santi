{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Santi Harmony – Static Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "Santi Harmony – Live Reload (live-server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", ".", "--port=3001", "--no-browser"],
      "port": 3001
    }
  ]
}
